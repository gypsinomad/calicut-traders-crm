rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function userId() {
      return request.auth.uid;
    }

    function isOwner(uid) {
      return isSignedIn() && userId() == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(userId())) && 
         get(/databases/$(database)/documents/users/$(userId())).data.role == 'admin') ||
        request.auth.token.email == 'akhilvenugopal@gmail.com'
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(userId())).data;
    }

    function isManager() {
      return isSignedIn() && (isAdmin() || getUserData().role == 'manager');
    }

    function belongsToOrg(org) {
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(userId())) && 
         getUserData().organization == org) ||
        org == "Calicut Traders" // Initial bootstrap fallback
      );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'status', 'createdAt', 'lastSeen', 'isOnline', 'presenceStatus']) &&
             data.uid == userId() &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['admin', 'manager', 'staff', 'user'] &&
             data.status in ['pending', 'active', 'suspended'] &&
             data.createdAt is timestamp &&
             data.lastSeen is timestamp &&
             data.isOnline is bool &&
             data.presenceStatus in ['online', 'away', 'offline', 'dnd'];
    }

    function isValidLead(data) {
      return data.keys().hasAll(['fullName', 'email', 'status', 'source', 'organization']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.email is string && data.email.size() > 0 &&
             data.status in ['new', 'contacted', 'qualified', 'quoted', 'converted', 'lost'] &&
             data.source in ['manual', 'website', 'whatsapp', 'tradeShow', 'referral', 'linkedin', 'emailCampaign', 'coldCall', 'importData'] &&
             data.organization is string && data.organization.size() > 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderNumber', 'customerName', 'commodity', 'quantity', 'unit', 'stage', 'totalAmount', 'totalValue', 'organization']) &&
             data.orderNumber is string && data.orderNumber.size() > 0 &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.commodity is string &&
             data.quantity is number &&
             data.stage in ['inquiry', 'quotationSent', 'piIssued', 'orderConfirmed', 'production', 'customs', 'shipped', 'inTransit', 'delivered', 'paymentReceived', 'cancelled', 'draft', 'leadReceived', 'exportDocumentation', 'shipmentReady', 'shippedDelivered'] &&
             data.totalAmount is number &&
             data.organization is string;
    }

    // ... other validation helpers ...

    // ===============================================================
    // Match Blocks
    // ===============================================================

    // --- Users ---
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || (isSignedIn() && belongsToOrg(resource.data.organization));
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(uid) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'avatarUrl', 'lastSeen', 'isOnline', 'presenceStatus', 'onboardingCompleted'])
        )
      );
      allow delete: if isAdmin();
    }

    // --- Organizations ---
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (isAdmin() || getUserData().organization == orgId);
      allow write: if isAdmin();

      match /ai_usage/{usageId} {
        allow read: if isSignedIn() && (isAdmin() || getUserData().organization == orgId);
        allow create: if isSignedIn() && (isAdmin() || getUserData().organization == orgId);
      }

      match /settings/integrations {
        allow read, write: if isAdmin() || (isManager() && getUserData().organization == orgId);
      }
    }

    // --- Leads ---
    match /leads/{leadId} {
      allow list: if isSignedIn() && resource.data.organization == getUserData().organization;
      allow get: if belongsToOrg(resource.data.organization);
      allow create: if belongsToOrg(incoming().organization) && isValidLead(incoming());
      allow update: if belongsToOrg(existing().organization) && (
        isAdmin() || isManager() || (isVerified() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'nextFollowUpAt', 'activityLog']))
      );
      allow delete: if isAdmin() || isManager();
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.organization == getUserData().organization;
      allow get: if belongsToOrg(resource.data.organization);
      allow create: if belongsToOrg(incoming().organization) && isValidOrder(incoming());
      allow update: if belongsToOrg(existing().organization);
      allow delete: if isAdmin() || isManager();
    }

    // --- Audit & Logs ---
    match /systemLogs/{logId} {
      allow read: if isAdmin() || isManager();
      allow create: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read: if belongsToOrg(resource.data.organization);
      allow create: if isSignedIn();
    }

    match /documentVersions/{versionId} {
      allow read: if isAdmin() || isManager();
      allow create: if isSignedIn();
    }

    match /trash/{trashId} {
      allow read: if isAdmin() || isManager();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // --- Catch-all for other collections ---
    match /{collection}/{docId} {
      allow read: if collection in ['companies', 'tasks', 'documents', 'inventory', 'market_prices', 'suppliers', 'quotes', 'payments', 'shipment_exceptions', 'generated_documents', 'send_history', 'calendar_events', 'chat_messages', 'daily_objectives', 'system_health'] &&
                   belongsToOrg(resource.data.organization);
      allow create: if collection in ['companies', 'tasks', 'documents', 'inventory', 'suppliers', 'quotes', 'payments', 'shipment_exceptions', 'generated_documents', 'send_history', 'calendar_events', 'chat_messages', 'daily_objectives'] &&
                   belongsToOrg(incoming().organization);
      allow update: if collection in ['companies', 'tasks', 'documents', 'inventory', 'suppliers', 'quotes', 'payments', 'shipment_exceptions', 'generated_documents', 'calendar_events', 'daily_objectives'] &&
                   belongsToOrg(existing().organization);
      allow delete: if isAdmin() || isManager();
    }
    
    // Notifications have a special case (bound to userId)
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn(); // System or team can create
      allow update: if isOwner(resource.data.userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
