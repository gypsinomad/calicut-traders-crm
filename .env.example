# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Meta (Facebook/Instagram) API
VITE_META_PAGE_ACCESS_TOKEN=your_meta_page_access_token
VITE_META_PAGE_ID=your_meta_page_id
VITE_META_APP_ID=your_meta_app_id
VITE_META_APP_SECRET=your_meta_app_secret

# WhatsApp Business API
VITE_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
VITE_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
VITE_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Anthropic Claude AI
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub (for Download App page - auto-set in CI/CD)
VITE_GITHUB_OWNER=gypsinomad
VITE_GITHUB_REPO=calicut-traders-crm

# App Configuration
VITE_APP_NAME=Calicut Traders CRM
VITE_APP_URL=https://your-domain.com
