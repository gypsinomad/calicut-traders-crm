# vertex AI
GCP_PROJECT_ID=
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1

# AI Security
AI_API_SECRET=your_long_random_secret_here

# WhatsApp Configuration
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Firebase configuration is handled automatically via firebase-applet-config.json


# WhatsApp Business API (Vite client-side)
VITE_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
VITE_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Meta Graph API
VITE_META_PAGE_ACCESS_TOKEN=your_meta_page_access_token_here
VITE_META_PAGE_ID=your_meta_page_id_here

# Zoho Mail API
VITE_ZOHO_MAIL_TOKEN=your_zoho_mail_oauth_token_here
VITE_ZOHO_MAIL_FROM=your_zoho_mail_from_address@domain.com

# Zoho Social API
VITE_ZOHO_SOCIAL_TOKEN=your_zoho_social_access_token_here

# GitHub repository info — used by the Download App page to fetch the latest APK release
# These are set automatically by GitHub Actions. Only needed for local dev.
VITE_GITHUB_OWNER=your-github-username
VITE_GITHUB_REPO=calicut-traders-crm

# Android APK Signing Secrets (add these in GitHub repo Settings → Secrets → Actions)
# KEYSTORE_BASE64=<base64-encoded-release.keystore>
# KEY_ALIAS=your_key_alias
# KEY_PASSWORD=your_key_password
# STORE_PASSWORD=your_store_password
VITE_ZOHO_SOCIAL_CLIENT_ID=your_zoho_social_client_id_here